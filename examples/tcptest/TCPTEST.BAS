10 MODE 2:MEMORY &3F0F
20 PRINT "Reading N4C.CFG..."
30 GOSUB 100
40 PRINT "OK - loading TCPTEST.BIN"
50 LOAD"TCPTEST.BIN",&4000
60 CALL &4000
70 END
100 OPENIN "N4C.CFG"
110 ba=&3F10:GOSUB 200
120 ba=&3F14:GOSUB 200
130 ba=&3F18:GOSUB 200
140 ba=&3F1C:GOSUB 200
150 CLOSEIN:RETURN
200 INPUT #9,a$:IF a$="" THEN 200
210 eq=INSTR(a$,"="):a$=MID$(a$,eq+1)
220 p=1:FOR oc=0 TO 3
230 q=INSTR(p,a$,"."):IF q=0 THEN q=LEN(a$)+1
240 POKE ba+oc,VAL(MID$(a$,p,q-p)):p=q+1
250 NEXT oc:RETURN
